# Local development defaults. Copy this file to .env.local or run
# ./scripts/dev-init.sh to generate a valid MASTER_KEY automatically.
APP_ENV=development
LISTEN_ADDR=127.0.0.1:8080
APP_BASE_URL=http://127.0.0.1:8080
DATABASE_URL=postgres://ikun:ServBay.dev@127.0.0.1:5432/cloud_account_manager?sslmode=disable

# Required: base64-encoded 32-byte AES key. Never change this key after
# credentials have been stored, or encrypted provider tokens become unreadable.
MASTER_KEY=

COOKIE_NAME=cloud_manager_session
COOKIE_SECURE=false
SESSION_TTL=168h
FRONTEND_DIR=web/dist
DEV_EXPOSE_TOKENS=true

# Local development embeds the worker in the API process. Production and
# Docker Compose run a separate worker process.
RUN_WORKER=true
WORKER_CONCURRENCY=4
WORKER_POLL_INTERVAL=2s
SYNC_INTERVAL=5m

# Docker Compose database defaults. These variables are ignored by the Go app.
POSTGRES_USER=ikun
POSTGRES_PASSWORD=ServBay.dev
POSTGRES_DB=cloud_account_manager
POSTGRES_PORT=5432
APP_PORT=8080

