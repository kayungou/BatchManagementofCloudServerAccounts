# Copy to .env.production on the production server. Never commit the real file.
APP_IMAGE=ghcr.io/ikun/cloud-account-manager:v0.1.0
APP_BASE_URL=https://cloud.example.com
APP_PORT=8080

POSTGRES_USER=cloudmanager
POSTGRES_PASSWORD=replace-with-a-long-random-value
POSTGRES_DB=cloud_account_manager

# Generate with: openssl rand -base64 32
# Back up this value together with the database. Never rotate it casually.
MASTER_KEY=replace-with-a-base64-encoded-32-byte-key

COOKIE_NAME=cloud_manager_session
SESSION_TTL=168h
WORKER_CONCURRENCY=4
WORKER_POLL_INTERVAL=2s
SYNC_INTERVAL=5m
